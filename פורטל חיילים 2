/* ── TOAST ── */
function showSoldierToast(msg) {
  const t = document.createElement('div');
  t.textContent = msg;
  t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0d0f14;border:1px solid rgba(245,200,66,0.35);color:var(--gold);padding:10px 22px;border-radius:10px;font-size:13px;font-family:"IBM Plex Mono",monospace;z-index:99999;box-shadow:0 4px 24px rgba(0,0,0,.5)';
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}
