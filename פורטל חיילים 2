// ── SIMULATOR ──────────────────────────────────────
function updateSim(){
  const pa=parseInt(document.getElementById('slider-phase-a').value);
  const pb=parseInt(document.getElementById('slider-phase-b').value);
  const bonus=parseInt(document.getElementById('slider-bonus').value);
  const housing=parseInt(document.getElementById('slider-housing').value);
  document.getElementById('val-phase-a').textContent=pa.toLocaleString();
  document.getElementById('val-phase-b').textContent=pb.toLocaleString();
  document.getElementById('val-bonus').textContent=bonus.toLocaleString();
  document.getElementById('val-housing').textContent=housing.toLocaleString();
  const annA=(pa+housing)*12, annB=pb*12;
  const total=annA*2+annB*2+bonus;
  const diff=total-22000*48;
  document.getElementById('out-annual-a').textContent='₪'+annA.toLocaleString();
  document.getElementById('out-annual-b').textContent='₪'+annB.toLocaleString();
  document.getElementById('out-total').textContent='₪'+total.toLocaleString();
  document.getElementById('out-diff').textContent=(diff>=0?'+':'')+'₪'+diff.toLocaleString();
  document.getElementById('out-diff').style.color=diff>=0?GOLD:RED;
  document.getElementById('out-after').textContent='₪'+(pb+7000).toLocaleString()+'+';
  document.getElementById('bar-a').style.width=Math.round((annA/(pb*12))*95)+'%';
  document.getElementById('bar-a').textContent=pa.toLocaleString()+'₪/חודש';
  document.getElementById('sal-a').textContent='₪'+(annA*2/1000).toFixed(0)+'K';
  document.getElementById('sal-b').textContent='₪'+(annB*2/1000).toFixed(0)+'K';
}

// ── TABS ──────────────────────────────────────────
function switchTab(screen,tab){
  document.querySelectorAll(`#screen-${screen} .tab-content`).forEach(t=>t.classList.remove('active'));
  document.querySelectorAll(`#screen-${screen} .tab-btn`).forEach(b=>b.classList.remove('active'));
  const el=document.getElementById(`${screen}-${tab}`);
  if(el)el.classList.add('active');
  event.target.classList.add('active');
}

function selectOption(card){
  card.closest('.options-grid')?.querySelectorAll('.option-card').forEach(c=>c.classList.remove('selected'));
  card.classList.add('selected');
}

