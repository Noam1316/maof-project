function renderPrefList(type) {
  const isSchool = type === 'school';
  const listEl   = document.getElementById(isSchool ? 'school-pref-list' : 'company-pref-list');
  const addEl    = document.getElementById(isSchool ? 'school-add-chips' : 'company-add-chips');
  const selected = isSchool ? prefSchools : prefCompanies;
  const all      = isSchool ? ALL_SCHOOLS : ALL_COMPANIES;

  // Render ranked list
  listEl.innerHTML = selected.length === 0
    ? `<div style="text-align:center;padding:20px;color:var(--text-dim);font-size:12px">עוד לא נבחרו ${isSchool?'בתי ספר':'חברות'} — לחצי למטה להוסיף</div>`
    : selected.map((id, i) => {
        const item = all.find(x => x.id === id);
        if (!item) return '';
        const matchColor = item.match >= 90 ? 'var(--gold)' : item.match >= 80 ? 'var(--teal)' : 'var(--amber)';
        const sub = isSchool
          ? `${item.city} · ${item.subject}${item.urgent ? ' · <span style="color:#e63946">דחוף</span>' : ''}`
          : `${item.role} · ${item.slots} slots`;
        return `<div class="rank-item" draggable="true" data-id="${id}" data-type="${type}">
          <div class="rank-num">${i+1}</div>
          <div style="flex:1">
            <div style="font-size:13px;font-weight:700;color:#fff">${item.name}</div>
            <div style="font-size:10px;color:var(--text-dim)">${sub}</div>
          </div>
          <div style="font-size:16px;font-weight:900;font-family:'IBM Plex Mono',monospace;color:${matchColor}">${item.match}%</div>
          <span class="rank-remove" onclick="removePreference('${id}','${type}')">✕</span>
        </div>`;
      }).join('');

  // Render add chips (items not yet selected)
  const remaining = all.filter(x => !selected.includes(x.id));
  addEl.innerHTML = remaining.map(item =>
    `<button onclick="addPreference('${item.id}','${type}')" class="pref-chip">+ ${item.name}</button>`
  ).join('') || `<span style="font-size:11px;color:var(--text-dim)">כל הפריטים נבחרו ✓</span>`;
}

function addPreference(id, type) {
  const list = type === 'school' ? prefSchools : prefCompanies;
  const max  = type === 'school' ? 5 : 5;
  if (list.includes(id)) return;
  if (list.length >= max) { showSoldierToast(`ניתן לבחור עד ${max} פריטים`); return; }
  list.push(id);
  renderPrefList(type);
}

function removePreference(id, type) {
  if (type === 'school')  prefSchools   = prefSchools.filter(x => x !== id);
  else                    prefCompanies = prefCompanies.filter(x => x !== id);
  renderPrefList(type);
}

function selectChip(btn, group) {
  btn.closest(`#${group}-chips, [id$="-chips"]`)?.querySelectorAll('.pref-chip').forEach(c => c.classList.remove('pref-chip-active'));
  btn.classList.add('pref-chip-active');
}

function toggleSubject(btn) {
  btn.classList.toggle('pref-chip-active');
}

function savePreferences() {
  const banner = document.getElementById('pref-saved-banner');
  if (banner) { banner.style.display = 'block'; setTimeout(() => banner.style.display = 'none', 4000); }
  showSoldierToast('✅ העדפות נשמרו בהצלחה');
  // Add confirmation message
  addMessage({
    id: 'm_pref_' + Date.now(), type: 'system', unread: false,
    icon: '⚙️', iconBg: 'rgba(122,162,247,0.15)',
    title: 'העדפות עודכנו',
    body: 'העדפותיך נשמרו. המשדך יעדכן את ההמלצות תוך 24 שעות.',
    time: 'עכשיו', tag: 'system'
  });
}

function resetPreferences() {
  prefSchools   = [];
  prefCompanies = [];
  renderPrefList('school');
  renderPrefList('company');
  showSoldierToast('↺ העדפות אופסו');
}

