let msgFilter = 'all';

function initMessages() {
  renderMessages();
  updateMsgBadge();
}

function renderMessages() {
  const list = document.getElementById('messages-list');
  if (!list) return;

  const filtered = MESSAGES.filter(m => {
    if (msgFilter === 'all')     return true;
    if (msgFilter === 'unread')  return m.unread;
    if (msgFilter === 'ministry')return m.tag === 'ministry';
    if (msgFilter === 'system')  return m.tag === 'system';
    return true;
  });

  if (filtered.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-dim);font-size:13px">אין הודעות בקטגוריה זו</div>';
    return;
  }

  list.innerHTML = filtered.map(m => `
    <div class="msg-card ${m.unread ? 'unread' : ''}" onclick="openMessage('${m.id}')">
      <div class="msg-icon" style="background:${m.iconBg}">${m.icon}</div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
          <span style="font-size:13px;font-weight:${m.unread?'700':'600'};color:${m.unread?'#fff':'var(--text)'}">${m.title}</span>
          ${m.tag==='ministry' ? '<span style="font-size:9px;padding:1px 6px;background:rgba(245,200,66,0.12);color:var(--gold);border-radius:4px;font-family:\'IBM Plex Mono\',monospace">מהמשרד</span>' : ''}
        </div>
        <div style="font-size:12px;color:var(--text-dim);line-height:1.5;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:90%">${m.body}</div>
        ${m.action ? `<button onclick="event.stopPropagation();msgAction('${m.id}')" style="margin-top:8px;padding:5px 14px;background:rgba(245,200,66,0.12);border:1px solid rgba(245,200,66,0.3);border-radius:7px;color:var(--gold);font-size:11px;cursor:pointer;font-family:'IBM Plex Mono',monospace">${m.action.label} →</button>` : ''}
      </div>
      <div style="font-size:10px;color:var(--text-dim);font-family:'IBM Plex Mono',monospace;white-space:nowrap;flex-shrink:0">${m.time}</div>
    </div>`).join('');
}

function openMessage(id) {
  const m = MESSAGES.find(x => x.id === id);
  if (!m) return;
  m.unread = false;
  updateMsgBadge();
  renderMessages();

  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:9999;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)';
  modal.innerHTML = `
    <div style="background:#0d0f14;border:1px solid rgba(245,200,66,0.2);border-radius:16px;padding:26px;max-width:460px;width:90vw;position:relative">
      <div style="position:absolute;top:0;right:0;left:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--teal));border-radius:16px 16px 0 0"></div>
      <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:16px">
        <div class="msg-icon" style="background:${m.iconBg};width:44px;height:44px;font-size:22px">${m.icon}</div>
        <div>
          <div style="font-size:15px;font-weight:800;color:#fff;margin-bottom:3px">${m.title}</div>
          <div style="font-size:10px;color:var(--text-dim);font-family:'IBM Plex Mono',monospace">${m.time}</div>
        </div>
      </div>
      <div style="font-size:13px;color:var(--text);line-height:1.7;margin-bottom:18px">${m.body}</div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button onclick="this.closest('[style*=fixed]').remove()" style="padding:8px 18px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);border-radius:8px;color:var(--text-dim);cursor:pointer;font-size:12px">סגור</button>
        ${m.action ? `<button onclick="msgAction('${m.id}');this.closest('[style*=fixed]').remove()" style="padding:8px 18px;background:linear-gradient(135deg,var(--gold),#e6b800);border:none;border-radius:8px;color:#0d0f14;font-weight:700;cursor:pointer;font-size:12px">${m.action.label} →</button>` : ''}
      </div>
    </div>`;
  document.body.appendChild(modal);
  modal.addEventListener('click', e => { if(e.target===modal) modal.remove(); });
}

function msgAction(id) {
  const m = MESSAGES.find(x => x.id === id);
  if (!m || !m.action) return;
  if (m.action.fn === 'confirmPlacement') {
    showSoldierToast('✅ קבלת ההצבה אושרה — אורט נתיבות');
    m.action = null;
    renderMessages();
  } else if (m.action.fn === 'viewMatch') {
    showScreen('schools');
  } else if (m.action.fn === 'respondToOffer') {
    showScreen('schools');
  }
}

function filterMessages(filter, btn) {
  msgFilter = filter;
  document.querySelectorAll('.msg-tab').forEach(t => t.classList.remove('msg-tab-active'));
  btn.classList.add('msg-tab-active');
  renderMessages();
}

function markAllRead() {
  MESSAGES.forEach(m => m.unread = false);
  updateMsgBadge();
  renderMessages();
  showSoldierToast('✓ כל ההודעות סומנו כנקראו');
}

function updateMsgBadge() {
  const unread = MESSAGES.filter(m => m.unread).length;
  const badge  = document.getElementById('msg-badge');
  if (badge) {
    badge.textContent = unread;
    badge.style.display = unread > 0 ? '' : 'none';
  }
  const label = document.getElementById('unread-count-label');
  if (label) label.textContent = unread > 0 ? `${unread} הודעות שלא נקראו` : 'כל ההודעות נקראו ✓';
}

function addMessage(msg) {
  MESSAGES.unshift(msg);
  updateMsgBadge();
}

