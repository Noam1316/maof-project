<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const GOLD='#f5c842',TEAL='#00d4aa',AMBER='#f4a261',BLUE='#7aa2f7',RED='#ff5c6a';
const grid='rgba(255,255,255,0.05)',tc='#6b7a99';
Chart.defaults.font.family="'IBM Plex Mono',monospace";
Chart.defaults.color=tc;

const navMap={dashboard:0,journey:1,schools:2,companies:3,upskill:4,simulator:5,checklist:6,preferences:7,messages:8,settings:9};
let initialized={};

function showScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.nav-item')[navMap[name]]?.classList.add('active');
  if(!initialized[name]){initialized[name]=true;initScreen(name);}
}

function initScreen(name){
  if(name==='dashboard')   initDashboard();
  if(name==='companies')   initCompanies();
  if(name==='simulator')   updateSim();
  if(name==='preferences') initPreferences();
  if(name==='messages')    initMessages();
}

// ── Unit talent scores ──────────────────────────────
const unitTalent={'8200':92,'intel':88,'comms':76,'air':82,'navy':74,'cyber':90,'other':62};
const subjectTech={'cyber':94,'python':88,'physics':72,'math':68,'electronics':75,'cs':85};
const cityRetention={'נתיבות':96,'אשקלון':92,'באר שבע':88,'קריית גת':91,'ראשון לציון':80,'תל אביב':74,'ירושלים':76,'חיפה':78,'נתניה':81,'אחר':70};

function calcScore(unit, subject, city){
  const talent = unitTalent[unit] || 70;
  const tech   = subjectTech[subject] || 70;
  const ret    = cityRetention[city] || 75;
  const urg    = city==='נתיבות'||city==='אשקלון'||city==='באר שבע'||city==='קריית גת' ? 85 : 62;
  return {
    talent, tech, ret, urg,
    total: Math.round((talent*0.25 + tech*0.25 + ret*0.25 + urg*0.25))
  };
}

// ── Live recalc when settings change ─────────────────
function liveRecalc(){
  const unit    = document.getElementById('s-unit')?.value || 'intel';
  const subject = document.getElementById('s-subject')?.value || 'cyber';
  const city    = document.getElementById('s-city')?.value || 'נתיבות';
  const s = calcScore(unit, subject, city);

  // Update score display
  const scoreEl = document.getElementById('settings-score');
  if(scoreEl) scoreEl.textContent = s.total;

  const update = (id, barId, val, pct) => {
    const el = document.getElementById(id);
    const bar = document.getElementById(barId);
    if(el) el.textContent = val;
    if(bar) bar.style.width = pct + '%';
  };
  update('sb-talent','sb-talent-bar', s.talent, s.talent);
  update('sb-tech','sb-tech-bar', s.tech, s.tech);
  update('sb-ret','sb-ret-bar', s.ret, s.ret);
  update('sb-urg','sb-urg-bar', s.urg, s.urg);

  // Update sidebar
  document.getElementById('sidebar-score').textContent = s.total;

  // Update name in sidebar from field
  const name = document.getElementById('s-name')?.value;
  if(name){
    document.getElementById('sidebar-name').textContent = name;
    const parts = name.trim().split(' ');
    const initials = parts.map(p=>p[0]||'').join('').slice(0,2);
    document.getElementById('sidebar-avatar').textContent = initials;
  }
}

function settingsDirty(){
  const bar = document.getElementById('settings-save-bar');
  if(bar){ bar.style.opacity='1'; bar.style.pointerEvents='auto'; }
  liveRecalc();
}

function saveSettings(){
  const name    = document.getElementById('s-name')?.value || '';
  const city    = document.getElementById('s-city')?.value || '';
  const unit    = document.getElementById('s-unit')?.value || '';
  const subject = document.getElementById('s-subject')?.value || '';

  // Update sidebar
  const parts = name.trim().split(' ');
  const initials = parts.map(p=>p[0]||'').join('').slice(0,2);
  document.getElementById('sidebar-name').textContent = name;
  document.getElementById('sidebar-avatar').textContent = initials;

  const unitLabel = document.getElementById('s-unit')?.selectedOptions[0]?.text || unit;
  const subjLabel = document.getElementById('s-subject')?.selectedOptions[0]?.text || subject;
  document.getElementById('sidebar-unit').textContent = `${unitLabel} | ${subjLabel}`;

  // Hide save bar
  const bar = document.getElementById('settings-save-bar');
  if(bar){ bar.style.opacity='0'; bar.style.pointerEvents='none'; }

  // Flash confirmation
  const btn = event?.target;
  if(btn){ const orig=btn.textContent; btn.textContent='✓ נשמר!'; btn.style.background='#00d4aa'; setTimeout(()=>{btn.textContent=orig;btn.style.background='';},2000); }
}

function toggleChip(el){ el.classList.toggle('selected'); }

// ── DASHBOARD ──────────────────────────────────────
function initDashboard(){
  new Chart(document.getElementById('canvas-radar-dash'),{
    type:'radar',
    data:{
      labels:['Talent','Retention','ELI5','Tech Match','Urgency'],
      datasets:[
        {label:'נועה לוי',data:[92,96,100,97,85],fill:true,backgroundColor:'rgba(245,200,66,0.12)',borderColor:GOLD,pointBackgroundColor:GOLD,borderWidth:2},
        {label:'ממוצע מחזור',data:[65,70,68,72,60],fill:true,backgroundColor:'rgba(255,255,255,0.04)',borderColor:'rgba(255,255,255,0.2)',pointBackgroundColor:'rgba(255,255,255,0.3)',borderWidth:1.5,borderDash:[4,3]}
      ]
    },
    options:{responsive:true,maintainAspectRatio:true,
      plugins:{legend:{position:'bottom',labels:{font:{size:10},boxWidth:10,padding:12}}},
      scales:{r:{min:0,max:100,grid:{color:grid},pointLabels:{font:{size:10},color:tc},ticks:{stepSize:25,display:false}}}}
  });
}

