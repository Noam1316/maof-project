function initCompanies(){
  new Chart(document.getElementById('canvas-salary-comp'),{
    type:'bar',
    data:{
      labels:['Mobileye','Check Point','Rafael','Waze','Amdocs','Tower Semi'],
      datasets:[{label:'שכר חזוי ₪/חודש',data:[28000,26000,24000,23000,22000,20000],
