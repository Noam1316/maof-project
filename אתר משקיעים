<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tech-Lead Israel — Investor Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:      #f7f8fa;
  --white:   #ffffff;
  --ink:     #0a0e1a;
  --ink2:    #1e2436;
  --ink3:    #2d3550;
  --mid:     #5a6480;
  --dim:     #9ba5bc;
  --border:  #e4e8f0;
  --border2: #f0f2f8;

  --gold:    #c9962a;
  --gold2:   #e8b84b;
  --gold-lt: #fef9ee;
  --gold-bg: #fffbf0;

  --green:   #0a7c5c;
  --green2:  #12a879;
  --green-lt:#ecfaf5;
  --red:     #c0392b;
  --red-lt:  #fff0ee;
  --blue:    #1a4db5;
  --blue-lt: #eff4ff;

  --shadow:  0 2px 12px rgba(10,14,26,.07);
  --shadow2: 0 8px 32px rgba(10,14,26,.1);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { height:100%; }
body {
  font-family:'DM Sans',sans-serif;
  background:var(--bg);
  color:var(--ink);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
}

/* ── TOPBAR ── */
.topbar {
  background:var(--ink);
  padding:0 36px;
  display:flex; align-items:center; gap:0;
  position:sticky; top:0; z-index:100;
  border-bottom:1px solid rgba(255,255,255,.06);
}
.tb-brand {
  display:flex; align-items:center; gap:14px;
  padding:15px 0;
  border-left:1px solid rgba(255,255,255,.1);
  padding-left:20px; margin-left:28px;
}
.tb-logo {
  width:34px; height:34px; border-radius:8px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  display:flex; align-items:center; justify-content:center;
  font-size:16px; flex-shrink:0;
}
.tb-name { font-size:15px; font-weight:700; color:#fff; letter-spacing:-.2px; }
.tb-name em { color:var(--gold2); font-style:normal; }
.tb-sub  { font-size:9px; color:rgba(255,255,255,.4); font-family:'DM Mono',monospace; letter-spacing:1.5px; text-transform:uppercase; }

.tb-tabs { display:flex; gap:0; }
.ttab {
  padding:17px 18px; font-size:12px; font-weight:600;
  color:rgba(255,255,255,.45); cursor:pointer;
  border-bottom:2px solid transparent; transition:all .15s;
  white-space:nowrap;
}
.ttab:hover { color:rgba(255,255,255,.8); }
.ttab.on { color:var(--gold2); border-bottom-color:var(--gold2); }

.tb-right {
  margin-right:auto; display:flex; align-items:center; gap:12px;
}
.live-tag {
  display:flex; align-items:center; gap:5px;
  padding:4px 10px; border-radius:4px;
  background:rgba(201,150,42,.12); border:1px solid rgba(201,150,42,.3);
  font-size:10px; font-weight:700; color:var(--gold2);
  font-family:'DM Mono',monospace; letter-spacing:.5px;
}
.live-dot { width:6px; height:6px; border-radius:50%; background:var(--gold2); animation:pulse 1.8s infinite; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.35;} }
.tb-quarter { font-size:10px; color:rgba(255,255,255,.3); font-family:'DM Mono',monospace; }
.export-btn {
  padding:7px 16px; border-radius:6px; border:1px solid rgba(255,255,255,.15);
  background:transparent; color:rgba(255,255,255,.7); font-size:12px; font-weight:600;
  font-family:'DM Sans',sans-serif; cursor:pointer; transition:all .15s;
}
.export-btn:hover { background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.3); color:#fff; }

/* ── SCREENS ── */
.screen { display:none; padding:32px 36px; animation:fadeUp .2s ease; }
.screen.on { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);} }

/* ── SECTION HEAD ── */
.sh { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:28px; }
.sh-left {}
.sh-eyebrow {
  font-size:9px; font-weight:700; color:var(--gold);
  text-transform:uppercase; letter-spacing:2px;
  font-family:'DM Mono',monospace; margin-bottom:6px;
}
.sh-title {
  font-family:'Playfair Display',serif;
  font-size:28px; font-weight:800; color:var(--ink);
  letter-spacing:-.5px; line-height:1.1;
}
.sh-title em { color:var(--gold); font-style:normal; }
.sh-sub { font-size:13px; color:var(--mid); margin-top:5px; }
.sh-right { display:flex; gap:8px; align-items:center; }

/* ── BUTTONS ── */
.btn {
  padding:8px 18px; border-radius:7px; border:none;
  font-family:'DM Sans',sans-serif; font-size:12px; font-weight:700;
  cursor:pointer; transition:all .15s;
}
.btn-gold { background:var(--gold); color:#fff; }
.btn-gold:hover { background:var(--gold2); box-shadow:0 4px 12px rgba(201,150,42,.35); }
.btn-outline { background:transparent; color:var(--mid); border:1.5px solid var(--border); }
.btn-outline:hover { border-color:var(--ink3); color:var(--ink); }

/* ── KPI STRIP ── */
.kpi-strip { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-bottom:24px; }
.kpi {
  background:var(--white); border:1px solid var(--border);
  border-radius:14px; padding:20px 22px;
  box-shadow:var(--shadow); position:relative; overflow:hidden;
  transition:transform .15s;
}
.kpi:hover { transform:translateY(-2px); }
.kpi-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
.kpi-lbl { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.7px; color:var(--dim); font-family:'DM Mono',monospace; }
.kpi-icon { font-size:16px; }
.kpi-val { font-size:30px; font-weight:700; line-height:1; font-family:'DM Mono',monospace; color:var(--ink); }
.kpi-val sup { font-size:14px; vertical-align:top; margin-top:4px; display:inline-block; }
.kpi-footer { display:flex; align-items:center; justify-content:space-between; margin-top:8px; }
.kpi-sub { font-size:11px; color:var(--dim); }
.kpi-delta {
  font-size:11px; font-weight:700; font-family:'DM Mono',monospace;
  padding:2px 7px; border-radius:4px;
}
.delta-up   { background:var(--green-lt); color:var(--green); }
.delta-down { background:var(--red-lt);   color:var(--red); }
.kpi-accent { position:absolute; bottom:0; left:0; right:0; height:3px; }
.accent-gold   { background:linear-gradient(90deg,var(--gold),var(--gold2)); }
.accent-green  { background:linear-gradient(90deg,var(--green),var(--green2)); }
.accent-blue   { background:linear-gradient(90deg,var(--blue),#4b8bf4); }
.accent-red    { background:linear-gradient(90deg,var(--red),#e74c3c); }
.accent-ink    { background:linear-gradient(90deg,var(--ink2),var(--ink3)); }

/* ── CARD ── */
.card {
  background:var(--white); border:1px solid var(--border);
  border-radius:14px; box-shadow:var(--shadow);
}
.card-hd {
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 22px 14px;
  border-bottom:1px solid var(--border2);
}
.card-title { font-size:12px; font-weight:700; color:var(--ink); text-transform:uppercase; letter-spacing:.5px; font-family:'DM Mono',monospace; }
.card-subtitle { font-size:11px; color:var(--dim); margin-top:2px; }
.card-action { font-size:11px; color:var(--gold); cursor:pointer; font-weight:700; }
.card-body { padding:20px 22px; }

/* ── GRIDS ── */
.g2  { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
.g3  { display:grid; grid-template-columns:1fr 1fr 1fr; gap:18px; }
.g32 { display:grid; grid-template-columns:3fr 2fr; gap:18px; }
.g23 { display:grid; grid-template-columns:2fr 3fr; gap:18px; }
.g13 { display:grid; grid-template-columns:1fr 3fr; gap:18px; }
.mb18 { margin-bottom:18px; }
.mb24 { margin-bottom:24px; }

/* ── TABLE ── */
.tbl { width:100%; border-collapse:collapse; }
.tbl th {
  padding:8px 12px; text-align:right;
  font-size:9px; font-weight:700; color:var(--dim);
  text-transform:uppercase; letter-spacing:.5px; font-family:'DM Mono',monospace;
  border-bottom:2px solid var(--border);
}
.tbl td { padding:10px 12px; font-size:12px; border-bottom:1px solid var(--border2); vertical-align:middle; }
.tbl tr:last-child td { border-bottom:none; }
.tbl tbody tr { transition:background .1s; }
.tbl tbody tr:hover { background:#fafbff; }

/* ── BADGES ── */
.badge {
  display:inline-flex; align-items:center; gap:4px;
  padding:3px 9px; border-radius:4px;
  font-size:10px; font-weight:700; font-family:'DM Mono',monospace;
}
.badge::before { content:''; width:5px; height:5px; border-radius:50%; }
.b-green { background:var(--green-lt); color:var(--green); border:1px solid rgba(10,124,92,.15); }
.b-green::before { background:var(--green2); }
.b-amber { background:var(--gold-lt); color:var(--gold); border:1px solid rgba(201,150,42,.25); }
.b-amber::before { background:var(--gold2); }
.b-red   { background:var(--red-lt);  color:var(--red); border:1px solid rgba(192,57,43,.15); }
.b-red::before   { background:var(--red); }
.b-blue  { background:var(--blue-lt); color:var(--blue); border:1px solid rgba(26,77,181,.15); }
.b-blue::before  { background:var(--blue); }

/* ── PROGRESS ── */
.pbar { height:5px; background:var(--border); border-radius:3px; overflow:hidden; }
.pbar-fill { height:100%; border-radius:3px; }

/* ── MAP SVG ── */
.map-wrap {
  position:relative; min-height:500px;
  background:linear-gradient(160deg,#f0f4ff 0%,#e8f0fe 100%);
  border-radius:12px; overflow:hidden; border:1px solid var(--border);
}
.map-svg { position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); }
.hs {
  position:absolute; cursor:pointer;
  transform:translate(-50%,-50%);
  display:flex; flex-direction:column; align-items:center; gap:4px;
  transition:transform .15s;
}
.hs:hover { transform:translate(-50%,-50%) scale(1.15); z-index:10; }
.hs-bubble {
  border-radius:50%; display:flex; align-items:center; justify-content:center;
  font-size:10px; font-weight:800; font-family:'DM Mono',monospace;
  color:#fff; position:relative; border:2px solid rgba(255,255,255,.7);
  box-shadow:0 2px 12px rgba(0,0,0,.2);
}
.hs-bubble::after {
  content:''; position:absolute;
  border-radius:50%; animation:hring 2.2s infinite;
  opacity:0; inset:-5px; border:2px solid currentColor;
}
@keyframes hring { 0%{transform:scale(1);opacity:.5;} 100%{transform:scale(1.7);opacity:0;} }
.hs-lbl {
  font-size:9px; font-weight:700; white-space:nowrap;
  padding:2px 6px; border-radius:3px;
  text-shadow:0 1px 2px rgba(0,0,0,.5);
}
.hs-crit .hs-bubble { background:var(--red);    color:var(--red); box-shadow:0 2px 12px rgba(192,57,43,.4); }
.hs-warn .hs-bubble { background:var(--gold);   color:var(--gold);  box-shadow:0 2px 12px rgba(201,150,42,.35); }
.hs-ok   .hs-bubble { background:var(--green2); color:var(--green2);box-shadow:0 2px 12px rgba(18,168,121,.35); }
.hs-crit .hs-bubble { color:#fff; }
.hs-warn .hs-bubble { color:#fff; }
.hs-ok   .hs-bubble { color:#fff; }
.hs-crit .hs-lbl { color:var(--red); }
.hs-warn .hs-lbl { color:var(--gold); }
.hs-ok   .hs-lbl { color:var(--green); }
.map-legend {
  position:absolute; bottom:14px; right:14px;
  background:rgba(255,255,255,.92); backdrop-filter:blur(8px);
  border:1px solid var(--border); border-radius:8px; padding:10px 13px;
}
.ml-row { display:flex; align-items:center; gap:6px; font-size:10px; color:var(--mid); margin-bottom:3px; }
.ml-row:last-child { margin-bottom:0; }
.ml-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

/* ── TIMELINE ── */
.tl { padding-right:20px; position:relative; }
.tl::before {
  content:''; position:absolute;
  right:6px; top:6px; bottom:6px; width:2px;
  background:linear-gradient(to bottom,var(--gold),var(--green),var(--blue),var(--border));
  border-radius:1px;
}
.tl-item {
  display:flex; gap:16px; margin-bottom:18px;
  animation:tlin .3s ease both;
}
.tl-item:nth-child(n) { animation-delay:calc(.06s * var(--i,0)); }
.tl-dot {
  width:14px; height:14px; border-radius:50%; flex-shrink:0;
  border:2px solid var(--bg); margin-top:2px;
  display:flex; align-items:center; justify-content:center;
  font-size:7px; color:#fff; font-weight:800; z-index:1;
}
@keyframes tlin { from{opacity:0;transform:translateX(8px);}to{opacity:1;transform:translateX(0);} }
.tl-date { font-size:10px; color:var(--dim); font-family:'DM Mono',monospace; margin-bottom:2px; }
.tl-title { font-size:12px; font-weight:700; color:var(--ink); }
.tl-sub { font-size:11px; color:var(--mid); margin-top:2px; line-height:1.5; }

/* ── RISK ROWS ── */
.risk-row {
  display:flex; align-items:flex-start; gap:12px;
  padding:13px 14px; border-radius:10px; margin-bottom:8px;
  border:1px solid;
}
.risk-row.hi  { background:#fff8f7; border-color:rgba(192,57,43,.18); }
.risk-row.mid { background:var(--gold-bg); border-color:rgba(201,150,42,.2); }
.risk-row.lo  { background:var(--green-lt); border-color:rgba(10,124,92,.15); }
.risk-icon { font-size:16px; flex-shrink:0; margin-top:1px; }
.risk-title { font-size:12px; font-weight:700; color:var(--ink); margin-bottom:3px; }
.risk-desc  { font-size:11px; color:var(--mid); line-height:1.5; }
.risk-cta   { font-size:11px; font-weight:700; margin-top:5px; cursor:pointer; }
.hi  .risk-cta { color:var(--red); }
.mid .risk-cta { color:var(--gold); }
.lo  .risk-cta { color:var(--green); }

/* ── FUNNEL ── */
.funnel-step {
  display:flex; align-items:center; gap:14px; margin-bottom:10px;
}
.f-label { font-size:12px; font-weight:600; width:130px; flex-shrink:0; color:var(--ink); }
.f-track { flex:1; }
.f-num { font-size:13px; font-weight:800; font-family:'DM Mono',monospace; width:42px; text-align:left; }
.f-pct { font-size:10px; color:var(--dim); font-family:'DM Mono',monospace; width:36px; }

/* ── COMPARISON ROWS ── */
.comp-row {
  display:flex; align-items:center; gap:12px;
  padding:10px 14px; border-radius:8px; margin-bottom:6px;
  border:1px solid var(--border2); background:var(--bg);
}
.cr-rank {
  width:22px; height:22px; border-radius:5px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  font-size:10px; font-weight:800; font-family:'DM Mono',monospace;
}
.rk1 { background:var(--gold);  color:#fff; }
.rk2 { background:var(--mid);   color:#fff; }
.rk3 { background:#92400e;      color:#fff; }
.rk_ { background:var(--border);color:var(--dim); }
.cr-name { font-size:12px; font-weight:700; color:var(--ink); flex:1; }
.cr-sub  { font-size:10px; color:var(--dim); }
.cr-bar-wrap { width:120px; }
.cr-val { font-size:13px; font-weight:800; font-family:'DM Mono',monospace; width:44px; text-align:left; }

/* ── HEATMAP ── */
.hmap { display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }
.hm {
  padding:12px 10px; border-radius:10px; text-align:center;
  border:1px solid var(--border); background:var(--white);
  transition:transform .15s; cursor:default;
}
.hm:hover { transform:translateY(-2px); box-shadow:var(--shadow); }
.hm-unit { font-size:10px; font-weight:700; color:var(--ink); margin-bottom:4px; }
.hm-val  { font-size:20px; font-weight:800; font-family:'DM Mono',monospace; }
.hm-sub  { font-size:9px; color:var(--dim); margin-top:2px; }

/* ── ROI CALLOUT ── */
.roi-callout {
  background:var(--ink); border-radius:14px;
  padding:28px 30px; position:relative; overflow:hidden;
}
.roi-callout::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,rgba(201,150,42,.08),transparent 60%);
}
.roi-eyebrow { font-size:9px; font-weight:700; color:rgba(255,255,255,.4); text-transform:uppercase; letter-spacing:2px; font-family:'DM Mono',monospace; margin-bottom:8px; }
.roi-title { font-family:'Playfair Display',serif; font-size:24px; font-weight:800; color:#fff; margin-bottom:6px; }
.roi-title em { color:var(--gold2); font-style:normal; }
.roi-sub { font-size:12px; color:rgba(255,255,255,.5); margin-bottom:22px; }
.roi-nums { display:grid; grid-template-columns:repeat(3,1fr); gap:0; }
.roi-num { text-align:center; padding:0 16px; border-left:1px solid rgba(255,255,255,.1); }
.roi-num:last-child { }
.roi-val { font-size:32px; font-weight:800; font-family:'DM Mono',monospace; }
.roi-val.gold { color:var(--gold2); }
.roi-val.green { color:var(--green2); }
.roi-val.white { color:#fff; }
.roi-lbl { font-size:10px; color:rgba(255,255,255,.4); margin-top:4px; font-family:'DM Mono',monospace; }

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width:4px; height:4px; }
::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
</style>
</head>
<body>

<!-- ── TOPBAR ── -->
<nav class="topbar">
  <div class="tb-brand">
    <div class="tb-logo">🎯</div>
    <div>
      <div class="tb-name">Tech-Lead <em>Israel</em></div>
      <div class="tb-sub">Investor Dashboard</div>
    </div>
  </div>

