        <div class="hm" style="border-color:rgba(18,168,121,.3);background:linear-gradient(135deg,rgba(18,168,121,.05),var(--white))">
          <div class="hm-unit">מודיעין</div>
          <div class="hm-val" style="color:var(--green)">91.7</div>
          <div class="hm-sub">62 מועמדים</div>
        </div>
        <div class="hm" style="border-color:rgba(6,182,212,.25)">
          <div class="hm-unit">סייבר</div>
          <div class="hm-val" style="color:#0891b2">89.4</div>
          <div class="hm-sub">31 מועמדים</div>
        </div>
        <div class="hm" style="border-color:rgba(26,77,181,.2)">
          <div class="hm-unit">חיל האוויר</div>
          <div class="hm-val" style="color:var(--blue)">85.1</div>
          <div class="hm-sub">28 מועמדים</div>
        </div>
        <div class="hm" style="border-color:var(--border)">
          <div class="hm-unit">הנדסה</div>
          <div class="hm-val" style="color:var(--mid)">80.4</div>
          <div class="hm-sub">22 מועמדים</div>
        </div>
        <div class="hm" style="border-color:var(--border)">
          <div class="hm-unit">תקשוב</div>
          <div class="hm-val" style="color:var(--dim)">78.3</div>
          <div class="hm-sub">54 מועמדים</div>
        </div>
        <div class="hm" style="border-color:var(--border)">
          <div class="hm-unit">חיל הים</div>
          <div class="hm-val" style="color:var(--dim)">74.9</div>
          <div class="hm-sub">25 מועמדים</div>
        </div>
        <div class="hm" style="border-color:var(--border)">
          <div class="hm-unit">קרבי</div>
          <div class="hm-val" style="color:var(--dim)">68.7</div>
          <div class="hm-sub">14 מועמדים</div>
        </div>
        <div class="hm" style="border-color:var(--border)">
          <div class="hm-unit">שדות</div>
          <div class="hm-val" style="color:var(--dim)">61.2</div>
          <div class="hm-sub">18 מועמדים</div>
        </div>
        <div class="hm" style="border-color:var(--border)">
          <div class="hm-unit">אחר</div>
          <div class="hm-val" style="color:var(--dim)">71.3</div>
          <div class="hm-sub">45 מועמדים</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
/* ── NAV ── */
const inited = {};
function go(name, el) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('on'));
  document.querySelectorAll('.ttab').forEach(t => t.classList.remove('on'));
  document.getElementById('s-'+name).classList.add('on');
  el.classList.add('on');
  if (!inited[name]) { inited[name] = true; initScreen(name); }
}

/* ── DATE ── */
const d = new Date();
document.getElementById('tb-date').textContent =
  d.toLocaleDateString('he-IL',{day:'numeric',month:'long',year:'numeric'});

/* ── CHART DEFAULTS ── */
Chart.defaults.font.family = "'DM Mono','DM Sans',sans-serif";
Chart.defaults.color = '#9ba5bc';
const GOLD='#c9962a', GOLD2='#e8b84b', GREEN='#12a879', GREEN2='#0a7c5c',
      BLUE='#1a4db5', RED='#c0392b', MID='#9ba5bc', GRID='rgba(10,14,26,.06)';

const baseOpts = (extra={}) => ({
  responsive:true, maintainAspectRatio:false,
  plugins:{ legend:{ position:'bottom', labels:{ font:{size:10}, boxWidth:10, padding:14 } } },
  scales:{
    x:{ grid:{display:false}, ticks:{font:{size:10}} },
    y:{ grid:{color:GRID}, ticks:{font:{size:10}} }
  }, ...extra
});

function initScreen(name) {
  if (name === 'financials') initFinancials();
  if (name === 'trends')     initTrends();
  if (name === 'compare')    initCompare();
}

/* ── FINANCIALS ── */
function initFinancials() {
  // Cost split donut
  new Chart(document.getElementById('c-split'), {
    type:'doughnut',
    data:{
      labels:['מדינה 50%','רשות מקומית 25%','חברה 25%'],
      datasets:[{
        data:[7500,3750,3750],
        backgroundColor:[BLUE+'cc',GOLD+'cc',GREEN+'cc'],
        borderColor:[BLUE,GOLD,GREEN], borderWidth:2
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false, cutout:'65%',
      plugins:{
        legend:{ position:'bottom', labels:{ font:{size:10}, boxWidth:10, padding:12 } },
        tooltip:{ callbacks:{ label:c=>' ₪'+c.raw.toLocaleString()+'/חודש' } }
      }
    }
  });

  // ROI over time
  new Chart(document.getElementById('c-roi'), {
    type:'line',
    data:{
      labels:['שלב 0','שנה 1 א\'','שנה 2 א\'','שנה 3 ב\'','שנה 4 ב\''],
      datasets:[
        { label:'עלות חברה מצטבר (₪)', data:[0,45000,90000,426000,762000],
          borderColor:RED, backgroundColor:RED+'18', fill:true, tension:.35,
          pointBackgroundColor:RED, pointRadius:4, borderWidth:2 },
        { label:'ערך שוק Senior מקביל', data:[0,130000,260000,520000,780000],
          borderColor:GREEN, backgroundColor:GREEN+'12', fill:true, tension:.35,
          pointBackgroundColor:GREEN, pointRadius:4, borderWidth:2, borderDash:[5,3] }
      ]
    },
    options: baseOpts({ plugins:{ legend:{ position:'bottom',labels:{font:{size:10},boxWidth:10,padding:12} },
      tooltip:{ callbacks:{ label:c=>' ₪'+c.raw.toLocaleString() } } },
      scales:{ x:{grid:{display:false},ticks:{font:{size:10}}},
               y:{grid:{color:GRID},ticks:{font:{size:10},callback:v=>'₪'+(v/1000)+'K'}} } })
  });
}

/* ── TRENDS ── */
function initTrends() {
  new Chart(document.getElementById('c-cohorts'), {
    type:'bar',
    data:{
      labels:['2021','2022','2023','2024','2025'],
      datasets:[
        { label:'נרשמו', data:[89,124,158,184,247],
          backgroundColor:BLUE+'33', borderColor:BLUE, borderWidth:2, borderRadius:4 },
        { label:'הוצבו', data:[24,41,58,72,89],
          backgroundColor:GOLD+'55', borderColor:GOLD, borderWidth:2, borderRadius:4 }
      ]
    },
    options: baseOpts()
  });

  new Chart(document.getElementById('c-ret'), {
    type:'line',
    data:{
      labels:['2021','2022','2023','2024','2025'],
      datasets:[
        { label:"Retention תחנה א'", data:[71,74,79,82,87],
          borderColor:GREEN, backgroundColor:GREEN+'18', fill:true, tension:.4,
          pointBackgroundColor:GREEN, pointRadius:5, borderWidth:2.5 },
        { label:"Retention תחנה ב'", data:[65,70,75,79,84],
          borderColor:GOLD2, backgroundColor:GOLD+'12', fill:true, tension:.4,
          pointBackgroundColor:GOLD2, pointRadius:4, borderWidth:2, borderDash:[5,4] }
      ]
    },
    options: baseOpts({ scales:{ x:{grid:{display:false},ticks:{font:{size:10}}},
      y:{grid:{color:GRID},min:55,max:100,ticks:{font:{size:10},callback:v=>v+'%'}} } })
  });

  new Chart(document.getElementById('c-salary'), {
    type:'line',
    data:{
      labels:['2021','2022','2023','2024','2025'],
      datasets:[{ label:"שכר ממוצע תחנה ב'",
        data:[19000,21000,24000,26000,28000],
        borderColor:GOLD, backgroundColor:GOLD+'18', fill:true, tension:.4,
        pointBackgroundColor:GOLD, pointRadius:5, borderWidth:2.5 }]
    },
    options: baseOpts({
      plugins:{ legend:{display:false}, tooltip:{callbacks:{label:c=>' ₪'+c.raw.toLocaleString()}} },
      scales:{ x:{grid:{display:false},ticks:{font:{size:10}}},
               y:{grid:{color:GRID},ticks:{font:{size:10},callback:v=>'₪'+(v/1000)+'K'}} }
    })
  });

  new Chart(document.getElementById('c-companies'), {
    type:'bar',
    data:{
      labels:['2021','2022','2023','2024','2025'],
      datasets:[{ label:'חברות מאמצות',
        data:[6,9,13,18,23],
        backgroundColor:[MID+'44',MID+'44',GOLD+'44',GREEN+'44',GREEN+'88'],
        borderColor:[MID,MID,GOLD,GREEN,GREEN], borderWidth:2, borderRadius:6 }]
    },
    options: baseOpts({ plugins:{legend:{display:false}} })
  });
}

/* ── COMPARE ── */
function initCompare() {
  new Chart(document.getElementById('c-radar'), {
    type:'radar',
    data:{
      labels:['ציון','Retention','ELI5','Tech Match','Seniority'],
      datasets:[
        { label:'8200',    data:[94,93,95,92,90],
          borderColor:GOLD,  backgroundColor:GOLD+'20',  pointBackgroundColor:GOLD,  borderWidth:2.5 },
        { label:'מודיעין', data:[92,89,90,88,88],
          borderColor:GREEN, backgroundColor:GREEN+'18', pointBackgroundColor:GREEN, borderWidth:2 },
        { label:'תקשוב',  data:[78,79,76,74,70],
          borderColor:MID,   backgroundColor:MID+'15',   pointBackgroundColor:MID,   borderWidth:1.5 },
      ]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{ position:'bottom', labels:{ font:{size:10}, boxWidth:10, padding:12 } } },
      scales:{ r:{ min:0, max:100,
        grid:{ color:GRID },
        pointLabels:{ font:{size:10}, color:MID },
        ticks:{ display:false, stepSize:25 }
      }}
    }
  });
}
</script>
</body>
</html>
