const injectStyles = () => {
  if (document.getElementById("tl-styles")) return;
  const s = document.createElement("style");
  s.id = "tl-styles";
  s.textContent = `
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&family=Playfair+Display:wght@700;800&display=swap');
    .tl-root { font-family: 'DM Sans', sans-serif; }
    .tl-root * { box-sizing: border-box; margin: 0; padding: 0; }
    .tl-root .mono { font-family: 'DM Mono', monospace; }
    .tl-root .serif { font-family: 'Playfair Display', serif; }
    @keyframes tl-fadeIn { from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);} }
    @keyframes tl-pulse  { 0%,100%{opacity:1;}50%{opacity:.35;} }
    @keyframes tl-spin   { to{transform:rotate(360deg);} }
    @keyframes tl-card-hover { to{transform:translateY(-3px);} }
    .tl-root .fade-in { animation: tl-fadeIn .25s ease both; }
    .tl-root::-webkit-scrollbar { width: 4px; }
    .tl-root::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 2px; }
  `;
  document.head.appendChild(s);
};

