  const PortalComponent = activePortal ? PORTAL_COMPONENTS[activePortal] : null;

  return (
    <div className="tl-root" style={{ height: "100vh", display: "flex", flexDirection: "column",
      background: T.ink, color: T.text, overflow: "hidden" }}>

      {!loggedIn ? (
        <LoginScreen onLogin={login} />
      ) : (
        <>
          {/* ── TOPBAR ── */}
          <div style={{
            display: "flex", alignItems: "center", gap: 0,
            background: T.ink2, borderBottom: `1px solid ${T.border}`,
            padding: "0 18px", flexShrink: 0, zIndex: 50,
          }}>
            {/* Brand */}
            <div style={{ display:"flex", alignItems:"center", gap:10,
              padding:"11px 16px 11px 0", borderLeft:`1px solid ${T.border}`, marginLeft:18 }}>
              <div style={{ width:26,height:26,borderRadius:7,
                background:`linear-gradient(135deg,${T.gold},${T.gold2})`,
                display:"flex",alignItems:"center",justifyContent:"center",fontSize:12 }}>🎯</div>
              <div style={{fontSize:13,fontWeight:700,color:T.white}}>
                Tech-Lead <span style={{color:T.gold2}}>Israel</span>
              </div>
            </div>

            {/* Portal tabs */}
            <div style={{ display:"flex", gap:0 }}>
              {Object.entries(PORTALS).map(([key, portal]) => (
                <div key={key}
                  onClick={() => setActivePortal(key)}
                  style={{
                    padding:"14px 15px", fontSize:12, fontWeight:600, cursor:"pointer",
                    color: activePortal===key ? portal.accent : T.mid,
                    borderBottom:`2px solid ${activePortal===key ? portal.accent : "transparent"}`,
                    transition:"all .15s", whiteSpace:"nowrap",
                  }}>
                  {portal.icon} {portal.label}
                </div>
              ))}
            </div>

            {/* Right side */}
            <div style={{ marginRight:"auto", display:"flex", alignItems:"center", gap:10 }}>
              {p && (
                <div style={{ display:"flex",alignItems:"center",gap:7,padding:"4px 12px",
                  borderRadius:20,background:"rgba(255,255,255,.05)",border:`1px solid ${T.border}`,fontSize:11,color:T.mid }}>
                  <div style={{ width:20,height:20,borderRadius:5,
                    background:`linear-gradient(135deg,${p.accent},${T.ink3})`,
                    display:"flex",alignItems:"center",justifyContent:"center",
                    fontSize:9,fontWeight:700,color:"#fff",flexShrink:0 }}>{p.initials}</div>
                  {p.user} · {p.role}
                </div>
              )}
              <button onClick={logout} style={{
                padding:"5px 14px", borderRadius:7,
                border:`1px solid ${T.border}`, background:"transparent",
                color:T.mid, fontSize:11, fontWeight:600,
                fontFamily:"'DM Sans',sans-serif", cursor:"pointer",
                transition:"all .15s",
              }}
              onMouseEnter={e=>{e.currentTarget.style.borderColor="rgba(220,38,38,.5)";e.currentTarget.style.color="#fca5a5";}}
              onMouseLeave={e=>{e.currentTarget.style.borderColor=T.border;e.currentTarget.style.color=T.mid;}}>
                ← יציאה
              </button>
            </div>
          </div>

          {/* ── PORTAL ── */}
          <div style={{ flex:1, overflow:"hidden" }}>
            {PortalComponent && <PortalComponent key={activePortal} />}
          </div>
        </>
      )}
    </div>
  );
}
