        &lt;select class=&quot;settings-input&quot; id=&quot;s-unit&quot; onchange=&quot;settingsDirty();liveRecalc()&quot;&gt;
          &lt;option value=&quot;8200&quot;&gt;8200&lt;/option&gt;
          &lt;option value=&quot;intel&quot; selected&gt;מודיעין&lt;/option&gt;
          &lt;option value=&quot;comms&quot;&gt;תקשוב&lt;/option&gt;
          &lt;option value=&quot;air&quot;&gt;חיל האוויר&lt;/option&gt;
