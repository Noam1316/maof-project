async function sendMsg() {
  const input = document.getElementById(&#x27;chat-input&#x27;);
  const q = input.value.trim();
  if (!q) return;

  input.value = &#x27;&#x27;;
  input.style.height = &#x27;auto&#x27;;
  const btn = document.getElementById(&#x27;chat-send-btn&#x27;);
  btn.disabled = true;
  stats.questions++;
  updateStats();

  appendMsg(&#x27;user&#x27;, q.replace(/\n/g,&#x27;&lt;br&gt;&#x27;));
  showThinking();

  // Build system prompt with full candidate data
  const systemPrompt = `אתה AI Matcher חכם לפורטל Tech-Lead Israel. החברה היא ${COMPANY_CONTEXT.name} (${COMPANY_CONTEXT.location}).
Tech Stack הנדרש: ${COMPANY_CONTEXT.stack.join(&#x27;, &#x27;)}.
תפקיד מוצע: ${COMPANY_CONTEXT.role}. שכר: ${COMPANY_CONTEXT.salary}₪. Slots: ${COMPANY_CONTEXT.slots}. Retention מינימלי: ${COMPANY_CONTEXT.minRetention}%.

מאגר המועמדים הזמין (JSON):
${JSON.stringify(ALL_CANDS_DATA, null, 2)}

הוראות:
- ענה בעברית, קצר וממוקד (2-4 משפטים מקסימום).
- אם המשתמש מחפש מועמדים — החזר JSON בתוך תג מיוחד: &lt;CANDIDATES&gt;[{&quot;id&quot;:&quot;...&quot;,&quot;reason&quot;:&quot;...&quot;}]&lt;/CANDIDATES&gt; עם עד 3 מועמדים מהמאגר לפי הרלוונטיות.
- אם זו שאלה כללית על עלויות/תנאים — ענה ישירות.
- אל תמציא מועמדים שלא קיימים במאגר.
- לכל מועמד שמחזיר, ציין סיבה קצרה מדוע הוא מתאים.`;

  chatHistory.push({ role:&#x27;user&#x27;, content: q });

  try {
    const resp = await fetch(&#x27;https://api.anthropic.com/v1/messages&#x27;, {
      method: &#x27;POST&#x27;,
      headers: { &#x27;Content-Type&#x27;: &#x27;application/json&#x27; },
      body: JSON.stringify({
        model: &#x27;claude-sonnet-4-20250514&#x27;,
        max_tokens: 1000,
        system: systemPrompt,
        messages: chatHistory,
      })
    });

    const data = await resp.json();
    const fullText = (data.content || []).map(b =&gt; b.text || &#x27;&#x27;).join(&#x27;&#x27;);
    chatHistory.push({ role: &#x27;assistant&#x27;, content: fullText });

    removeThinking();

    // Check for candidate results
    const candMatch = fullText.match(/&lt;CANDIDATES&gt;([\s\S]*?)&lt;\/CANDIDATES&gt;/);
    const cleanText = fullText.replace(/&lt;CANDIDATES&gt;[\s\S]*?&lt;\/CANDIDATES&gt;/, &#x27;&#x27;).trim();

    if (candMatch) {
      try {
        const ids = JSON.parse(candMatch[1]);
        const enriched = ids.map(item =&gt; {
          const c = ALL_CANDS_DATA.find(d =&gt; d.id === item.id);
          return c ? { ...c, reason: item.reason } : null;
        }).filter(Boolean);

        let intro = cleanText || `מצאתי ${enriched.length} מועמדים מתאימים:`;
        // Add reasoning
        if (enriched.length &gt; 0 &amp;&amp; enriched[0].reason) {
          intro += `&lt;br&gt;&lt;small style=&quot;opacity:.7&quot;&gt;המלצה ראשונה: ${enriched[0].reason}&lt;/small&gt;`;
        }
        renderCandCards(enriched, intro);
      } catch {
        appendMsg(&#x27;ai&#x27;, cleanText || fullText);
      }
    } else {
      appendMsg(&#x27;ai&#x27;, (cleanText || fullText).replace(/\n/g, &#x27;&lt;br&gt;&#x27;));
    }

  } catch (err) {
    removeThinking();
    // Fallback: local matching when API unavailable
    localMatch(q);
  }

  btn.disabled = false;
}

// Local fallback matching (no API needed)
function localMatch(q) {
  const ql = q.toLowerCase();
  let filtered = [...ALL_CANDS_DATA];

  // Simple keyword matching
  if (ql.includes(&#x27;8200&#x27;))          filtered = filtered.filter(c =&gt; c.unit === &#x27;8200&#x27;);
  if (ql.includes(&#x27;מודיעין&#x27;))        filtered = filtered.filter(c =&gt; c.unit === &#x27;מודיעין&#x27;);
  if (ql.includes(&#x27;סייבר&#x27;) || ql.includes(&#x27;cyber&#x27;)) filtered = filtered.filter(c =&gt; c.stack.some(s =&gt; s.toLowerCase().includes(&#x27;cyber&#x27;)));
  if (ql.includes(&#x27;python&#x27;))         filtered = filtered.filter(c =&gt; c.stack.some(s =&gt; s.toLowerCase().includes(&#x27;python&#x27;)));
