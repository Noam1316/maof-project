  font-family: &#x27;DM Sans&#x27;, sans-serif; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: all .15s; white-space: nowrap;
}
.btn-primary { background: var(--blue); color: #fff; }
.btn-primary:hover { background: var(--blue-mid); box-shadow: 0 3px 10px rgba(37,99,235,.3); }
.btn-green { background: var(--green); color: #fff; }
.btn-green:hover { background: #047857; }
.btn-outline { background: transparent; color: var(--blue); border: 1.5px solid var(--blue); }
.btn-outline:hover { background: var(--blue-lt); }
.btn-ghost { background: var(--surface); color: var(--text-mid); border: 1.5px solid var(--border); box-shadow: var(--shadow-sm); }
.btn-ghost:hover { border-color: var(--slate); color: var(--text); }

/* ─── CARDS ──────────────────────────────────── */
.card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; box-shadow: var(--shadow);
}
.card-p { padding: 20px 22px; }
.card-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 22px 14px;
}
.card-title { font-size: 13px; font-weight: 600; color: var(--text); }
.card-link { font-size: 12px; color: var(--blue); cursor: pointer; font-weight: 500; }
.card-bd { padding: 4px 22px 18px; }

/* ─── KPI ROW ────────────────────────────────── */
.kpi-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 20px; }
.kpi {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 16px 18px;
  box-shadow: var(--shadow); position: relative; overflow: hidden;
  transition: transform .15s;
}
.kpi:hover { transform: translateY(-2px); }
.kpi-lbl {
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .6px; color: var(--text-dim); margin-bottom: 7px;
}
.kpi-val {
  font-size: 26px; font-weight: 700; line-height: 1;
  font-family: &#x27;DM Mono&#x27;, monospace;
}
.kpi-sub { font-size: 11px; color: var(--text-dim); margin-top: 4px; }
.kpi-accent { position: absolute; bottom: 0; left: 0; right: 0; height: 3px; border-radius: 0 0 12px 12px; }
.c-blue { color: var(--blue); } .a-blue { background: var(--blue); }
.c-green { color: var(--green); } .a-green { background: var(--green); }
.c-amber { color: var(--amber); } .a-amber { background: var(--amber); }
.c-red { color: var(--red); } .a-red { background: var(--red); }

/* ─── TABLE ──────────────────────────────────── */
.tbl-wrap {
  border-radius: 12px; overflow: hidden;
  border: 1px solid var(--border); box-shadow: var(--shadow);
}
table { width: 100%; border-collapse: collapse; background: var(--card); }
thead tr { background: #f8fafc; }
th {
  padding: 10px 14px; text-align: right;
  font-size: 10px; font-weight: 600; color: var(--text-dim);
  text-transform: uppercase; letter-spacing: .5px;
  border-bottom: 1px solid var(--border); white-space: nowrap;
}
td { padding: 12px 14px; border-bottom: 1px solid var(--border2); vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody tr { cursor: pointer; transition: background .1s; }
tbody tr:hover { background: #f9fafb; }

/* ─── SCORE PILL ─────────────────────────────── */
.score {
  display: inline-flex; align-items: center; justify-content: center;
  width: 36px; height: 26px; border-radius: 6px;
  font-size: 12px; font-weight: 700; font-family: &#x27;DM Mono&#x27;, monospace;
}
.score-hi { background: var(--green-lt); color: var(--green); }
.score-mid { background: var(--amber-lt); color: var(--amber); }
.score-lo { background: var(--red-lt); color: var(--red); }

/* ─── MATCH BAR ──────────────────────────────── */
.mbar { display: flex; align-items: center; gap: 8px; min-width: 90px; }
.mbar-track { flex: 1; height: 5px; background: var(--border); border-radius: 3px; overflow: hidden; }
.mbar-fill { height: 100%; border-radius: 3px; }
.mbar-pct { font-size: 11px; font-weight: 600; font-family: &#x27;DM Mono&#x27;, monospace; width: 30px; }

/* ─── STATUS ─────────────────────────────────── */
.status {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 600;
}
.status::before { content: &#x27;&#x27;; width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
.st-avail { background: var(--green-lt); color: var(--green); }
.st-avail::before { background: var(--green); }
.st-placed { background: var(--blue-lt); color: var(--blue); }
.st-placed::before { background: var(--blue); }
.st-pending { background: var(--amber-lt); color: var(--amber); }
.st-pending::before { background: var(--amber); }

/* ─── CANDIDATE ROW ──────────────────────────── */
.cand { display: flex; align-items: center; gap: 10px; }
.cand-av {
  width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; color: #fff;
}
.cand-name { font-size: 13px; font-weight: 600; color: var(--text); }
.cand-unit { font-size: 11px; color: var(--text-dim); margin-top: 1px; }

/* ─── CHIP ───────────────────────────────────── */
.chip {
  display: inline-flex; align-items: center;
  padding: 2px 8px; border-radius: 5px;
  font-size: 11px; font-weight: 600; margin: 1px;
}
.chip-blue { background: var(--blue-lt); color: var(--blue); }
.chip-green { background: var(--green-lt); color: var(--green); }
.chip-gray { background: #f1f5f9; color: var(--slate); }
.chip-amber { background: var(--amber-lt); color: var(--amber); }

/* ─── FILTER BAR ─────────────────────────────── */
.filter-bar { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
.filter-chip {
  padding: 5px 13px; border-radius: 20px; font-size: 12px; font-weight: 600;
  border: 1.5px solid var(--border); background: var(--card);
  cursor: pointer; color: var(--text-mid); transition: all .14s;
}
.filter-chip:hover { border-color: var(--blue); color: var(--blue); }
.filter-chip.on { background: var(--blue-lt); border-color: var(--blue); color: var(--blue); }
.search-box {
  padding: 6px 13px; border-radius: 8px; border: 1.5px solid var(--border);
  font-family: &#x27;DM Sans&#x27;, sans-serif; font-size: 13px; color: var(--text);
  outline: none; background: var(--card); min-width: 200px; transition: border .15s;
}
.search-box:focus { border-color: var(--blue); }

/* ─── MODAL ──────────────────────────────────── */
.modal-bg {
  position: fixed; inset: 0;
  background: rgba(15,23,42,.4); backdrop-filter: blur(4px);
  z-index: 200; display: none; align-items: center; justify-content: center; padding: 20px;
}
.modal-bg.open { display: flex; }
.modal {
  background: #fff; border-radius: 16px; box-shadow: var(--shadow-lg);
  width: 100%; max-width: 660px; max-height: 90vh; overflow-y: auto;
  animation: modalIn .22s ease;
}
@keyframes modalIn { from { opacity:0; transform:scale(.96) translateY(10px); } to { opacity:1; transform:scale(1) translateY(0); } }
.modal-head {
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 14px; position: sticky; top: 0; background: #fff; z-index: 1;
}
.modal-av {
  width: 48px; height: 48px; border-radius: 12px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 17px; font-weight: 700; color: #fff;
}
.modal-name { font-size: 17px; font-weight: 700; color: var(--text); }
.modal-unit { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
.modal-x {
  margin-right: auto; width: 28px; height: 28px; border: 1.5px solid var(--border);
  border-radius: 6px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text-dim); font-size: 13px; flex-shrink: 0; transition: all .15s;
}
.modal-x:hover { background: #f1f5f9; color: var(--text); }
.modal-body { padding: 20px 24px; }
.modal-kpi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 20px; }
.mkpi { background: #f8fafc; border-radius: 10px; padding: 13px; text-align: center; border: 1px solid var(--border2); }
.mkpi-lbl { font-size: 9px; font-weight: 600; color: var(--text-dim); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
.mkpi-val { font-size: 21px; font-weight: 700; font-family: &#x27;DM Mono&#x27;, monospace; }
.modal-section { margin-bottom: 18px; }
.modal-sec-title { font-size: 10px; font-weight: 600; color: var(--text-dim); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }
.journey { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; border-radius: 9px; overflow: hidden; border: 1px solid var(--border); }
.journey-phase { padding: 12px; text-align: center; background: #f8fafc; }
.journey-phase.a { background: var(--blue-lt); border: 1px solid #bfdbfe; }
.journey-phase.b { background: var(--green-lt); border: 1px solid #bbf7d0; }
.jp-lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--text-dim); margin-bottom: 4px; }
.jp-val { font-size: 13px; font-weight: 700; color: var(--text); }
.jp-sub { font-size: 10px; color: var(--text-dim); margin-top: 2px; }
.modal-foot { display: flex; gap: 8px; padding: 14px 24px 20px; border-top: 1px solid var(--border); }

/* ─── NOTIFICATION ───────────────────────────── */
.notif {
  display: flex; gap: 12px; align-items: flex-start;
  padding: 12px 16px; border-radius: 9px; border: 1px solid var(--border);
  background: var(--card); margin-bottom: 8px; transition: background .1s; cursor: pointer;
}
.notif:hover { background: #f9fafb; }
.notif.unread { background: #eff6ff; border-color: #bfdbfe; }
.notif-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.notif-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
.notif-sub { font-size: 11px; color: var(--text-dim); }
.notif-time { font-size: 10px; color: var(--text-dim); white-space: nowrap; font-family: &#x27;DM Mono&#x27;, monospace; margin-top: 2px; }

/* ─── PROGRESS ───────────────────────────────── */
.progress-track { height: 6px; background: var(--border); border-radius: 4px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 4px; transition: width .6s ease; }

/* ─── AGREE STEP ─────────────────────────────── */
.agree-row {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 16px; border-radius: 9px;
  border: 1px solid var(--border); background: var(--card); margin-bottom: 8px;
}
.agree-num {
  width: 24px; height: 24px; border-radius: 6px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700;
}
.an-done { background: var(--green-lt); color: var(--green); }
.an-active { background: var(--blue); color: #fff; }
.an-todo { background: #f1f5f9; color: var(--text-dim); }
.agree-label { flex: 1; font-size: 13px; font-weight: 500; color: var(--text); }
.agree-date { font-size: 11px; color: var(--text-dim); font-family: &#x27;DM Mono&#x27;, monospace; }
.agree-action { font-size: 12px; color: var(--blue); cursor: pointer; font-weight: 600; }

/* ─── SETTINGS FORM ──────────────────────────── */
.sf-section { margin-bottom: 24px; }
.sf-sec-title {
  font-size: 10px; font-weight: 700; color: var(--text-dim);
  text-transform: uppercase; letter-spacing: .6px;
  margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border2);
}
.sf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 13px; }
.sf-field { display: flex; flex-direction: column; gap: 5px; }
.sf-field.full { grid-column: span 2; }
.sf-lbl { font-size: 11px; font-weight: 500; color: var(--text-mid); }
.sf-input {
  padding: 9px 13px; border-radius: 8px; border: 1.5px solid var(--border);
  font-family: &#x27;DM Sans&#x27;, sans-serif; font-size: 13px; color: var(--text);
  outline: none; transition: border .15s; background: #fff; width: 100%;
}
.sf-input:focus { border-color: var(--blue); }
select.sf-input { cursor: pointer; -webkit-appearance: none; }
.tc-group { display: flex; flex-wrap: wrap; gap: 6px; }
.tc {
  padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;
  border: 1.5px solid var(--border); background: #f8fafc;
  cursor: pointer; color: var(--text-mid); transition: all .14s;
}
.tc:hover { border-color: var(--blue); color: var(--blue); }
.tc.on { border-color: var(--blue); background: var(--blue-lt); color: var(--blue); }
.save-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px; border-radius: 8px; margin-top: 16px;
  background: var(--amber-lt); border: 1px solid #fde68a;
  opacity: 0; pointer-events: none; transition: opacity .25s;
}
.save-bar.show { opacity: 1; pointer-events: auto; }

/* ─── FINANCE ROWS ───────────────────────────── */
.fin-row {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 0; border-bottom: 1px solid var(--border2);
}
.fin-row:last-child { border-bottom: none; }
.fin-who { font-size: 13px; color: var(--text-mid); width: 160px; flex-shrink: 0; }
.fin-track { flex: 1; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
.fin-fill { height: 100%; border-radius: 3px; }
.fin-pct { font-size: 12px; font-weight: 600; color: var(--text-mid); width: 36px; text-align: center; }
.fin-amt { font-size: 14px; font-weight: 700; font-family: &#x27;DM Mono&#x27;, monospace; width: 76px; text-align: left; }

/* ─── GRID HELPERS ───────────────────────────── */
.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.g3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.g-21 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; }
.mb16 { margin-bottom: 16px; }
.mb20 { margin-bottom: 20px; }

/* ─── AI CHAT ────────────────────────────────── */
.chat-shell {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 18px;
  height: calc(100vh - 120px);
}
.chat-main {
  display: flex; flex-direction: column;
  background: var(--card); border: 1px solid var(--border);
  border-radius: 14px; box-shadow: var(--shadow); overflow: hidden;
}
.chat-topbar {
  padding: 14px 20px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 12px;
  background: linear-gradient(135deg, #f0f6ff, #fff);
}
.chat-ai-av {
  width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
  background: linear-gradient(135deg, var(--blue), #7c3aed);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}
.chat-ai-name { font-size: 13px; font-weight: 700; color: var(--text); }
.chat-ai-sub { font-size: 11px; color: var(--text-dim); }
.chat-online {
  margin-right: auto; display: flex; align-items: center; gap: 5px;
  font-size: 11px; color: var(--green); font-weight: 600;
}
.chat-online::before { content:&#x27;&#x27;; width:7px; height:7px; border-radius:50%; background:var(--green); box-shadow:0 0 5px var(--green); }

.chat-messages {
  flex: 1; overflow-y: auto; padding: 20px;
  display: flex; flex-direction: column; gap: 14px;
  scroll-behavior: smooth;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.msg { display: flex; gap: 10px; max-width: 85%; animation: msgIn .2s ease; }
@keyframes msgIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
.msg.user { margin-right: auto; flex-direction: row-reverse; }
.msg.ai { margin-left: auto; }
.msg-av {
  width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0; margin-top: 2px;
  display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;
}
.msg-av.ai-av { background: linear-gradient(135deg, var(--blue), #7c3aed); color: #fff; font-size: 14px; }
.msg-av.user-av { background: linear-gradient(135deg, #16213e, #2563eb); color: #fff; font-size: 10px; }
.msg-bubble {
  padding: 11px 14px; border-radius: 12px; font-size: 13px; line-height: 1.55;
}
.msg.user .msg-bubble {
  background: var(--blue); color: #fff;
  border-radius: 12px 2px 12px 12px;
}
.msg.ai .msg-bubble {
  background: #f4f7fc; color: var(--text); border: 1px solid var(--border);
  border-radius: 2px 12px 12px 12px;
}
.msg-time { font-size: 10px; color: var(--text-dim); margin-top: 4px; text-align: left; }
.msg.user .msg-time { text-align: right; }

/* candidate result cards inside chat */
.chat-cand-card {
  background: #fff; border: 1px solid var(--border);
  border-radius: 10px; padding: 12px 14px; margin-top: 8px;
  cursor: pointer; transition: all .15s;
  display: flex; align-items: center; gap: 12px;
}
.chat-cand-card:hover { border-color: var(--blue); background: var(--blue-lt); transform: translateY(-1px); box-shadow: var(--shadow); }
.chat-cand-card.rank-1 { border-color: var(--green); background: var(--green-lt); }
.ccc-rank {
  width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 800;
}
.r1 { background: var(--green); color: #fff; }
.r2 { background: var(--blue); color: #fff; }
.r3 { background: #94a3b8; color: #fff; }
.ccc-name { font-size: 13px; font-weight: 700; color: var(--text); }
.ccc-unit { font-size: 11px; color: var(--text-dim); margin-top: 1px; }
.ccc-score { font-size: 15px; font-weight: 800; font-family: &#x27;DM Mono&#x27;, monospace; margin-right: auto; }
.ccc-match { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px; }

/* thinking indicator */
.thinking {
  display: flex; gap: 10px; align-items: center;
  padding: 11px 14px; background: #f4f7fc; border: 1px solid var(--border);
  border-radius: 2px 12px 12px 12px; font-size: 13px; color: var(--text-dim);
}
.thinking-dots { display: flex; gap: 4px; }
.thinking-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--blue);
  animation: tdot .9s infinite;
}
.thinking-dot:nth-child(2) { animation-delay: .15s; }
.thinking-dot:nth-child(3) { animation-delay: .3s; }
@keyframes tdot { 0%,60%,100%{transform:translateY(0);opacity:.4;} 30%{transform:translateY(-5px);opacity:1;} }

.chat-input-wrap {
  padding: 14px 16px; border-top: 1px solid var(--border);
  display: flex; gap: 10px; align-items: flex-end;
  background: #fafbfc;
}
.chat-input {
  flex: 1; padding: 10px 14px; border-radius: 10px;
  border: 1.5px solid var(--border); background: #fff;
  font-family: &#x27;DM Sans&#x27;, sans-serif; font-size: 13px; color: var(--text);
  outline: none; resize: none; line-height: 1.5; max-height: 100px;
  transition: border .15s;
}
.chat-input:focus { border-color: var(--blue); }
.chat-send {
  width: 38px; height: 38px; border-radius: 10px; border: none;
  background: var(--blue); color: #fff; font-size: 16px;
  cursor: pointer; transition: all .15s; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.chat-send:hover { background: var(--blue-mid); transform: translateY(-1px); }
.chat-send:disabled { background: #cbd5e1; cursor: not-allowed; transform: none; }

/* sidebar panel */
.chat-sidebar { display: flex; flex-direction: column; gap: 14px; overflow-y: auto; }
.prompt-chip {
  display: flex; align-items: flex-start; gap: 8px;
  padding: 10px 12px; background: var(--card); border: 1.5px solid var(--border);
  border-radius: 9px; cursor: pointer; transition: all .15s; font-size: 12px;
  color: var(--text-mid); line-height: 1.4;
}
.prompt-chip:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-lt); }
.prompt-chip .pi { font-size: 15px; flex-shrink: 0; margin-top: 1px; }
.context-item {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 12px; padding: 6px 0; border-bottom: 1px solid var(--border2);
}
.context-item:last-child { border-bottom: none; }
.context-key { color: var(--text-dim); }
.context-val { font-weight: 600; color: var(--text); font-family: &#x27;DM Mono&#x27;, monospace; }
