          &lt;option value=&quot;cyber&quot;&gt;סייבר / הגנה&lt;/option&gt;
          &lt;option value=&quot;other&quot;&gt;אחר&lt;/option&gt;
        &lt;/select&gt;
      &lt;/div&gt;

      &lt;!-- מקצוע --&gt;
      &lt;div class=&quot;settings-field&quot;&gt;
        &lt;div class=&quot;settings-label&quot;&gt;מקצוע הוראה &lt;small style=&quot;color:var(--text-dim);font-weight:400&quot;&gt;— משפיע על Tech Match&lt;/small&gt;&lt;/div&gt;
        &lt;select class=&quot;settings-input&quot; id=&quot;s-subject&quot; onchange=&quot;settingsDirty();liveRecalc()&quot;&gt;
          &lt;option value=&quot;cyber&quot; selected&gt;סייבר&lt;/option&gt;
          &lt;option value=&quot;python&quot;&gt;Python &amp; AI&lt;/option&gt;
          &lt;option value=&quot;physics&quot;&gt;פיזיקה&lt;/option&gt;
          &lt;option value=&quot;math&quot;&gt;מתמטיקה&lt;/option&gt;
          &lt;option value=&quot;electronics&quot;&gt;אלקטרוניקה&lt;/option&gt;
