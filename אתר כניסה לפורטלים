<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tech-Lead Israel — Platform</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --ink:    #0a0e1a;
  --ink2:   #1e2436;
  --bg:     #f0f2f7;
  --white:  #ffffff;
  --border: rgba(255,255,255,.1);
  --gold:   #c9962a;
  --gold2:  #e8b84b;
  --blue:   #2563eb;
  --teal:   #0891b2;
  --green:  #059669;
  --purple: #7c3aed;
  --text:   #e2e8f0;
  --mid:    rgba(255,255,255,.45);
  --dim:    rgba(255,255,255,.22);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{font-family:'DM Sans',sans-serif;background:var(--ink);color:var(--text);display:flex;flex-direction:column;}

/* ── AMBIENT ── */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 40% at 80% 10%, rgba(201,150,42,.06) 0%, transparent 60%),
    radial-gradient(ellipse 45% 50% at 10% 90%, rgba(37,99,235,.05)  0%, transparent 60%);
}

/* ══ LOGIN SCREEN ══ */
#login-screen{
  position:fixed;inset:0;z-index:200;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--ink);
  animation:fadeIn .3s ease;
  padding:20px;
}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
@keyframes fadeOut{from{opacity:1;}to{opacity:0;pointer-events:none;}}
.login-screen-hidden{animation:fadeOut .3s ease forwards!important;pointer-events:none;}

.login-brand{text-align:center;margin-bottom:44px;}
.login-logo{
  width:64px;height:64px;border-radius:16px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  display:flex;align-items:center;justify-content:center;
  font-size:28px;margin:0 auto 16px;
  box-shadow:0 8px 32px rgba(201,150,42,.3);
}
.login-name{font-size:28px;font-weight:700;color:#fff;letter-spacing:-.5px;}
.login-name em{color:var(--gold2);font-style:normal;}
.login-sub{font-size:13px;color:var(--mid);margin-top:5px;}

.login-label{font-size:11px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:1.5px;font-family:'DM Mono',monospace;margin-bottom:14px;text-align:center;}

.portals-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;width:100%;max-width:560px;}

.portal-card{
  border-radius:16px;border:1px solid rgba(255,255,255,.08);
  cursor:pointer;transition:all .18s;position:relative;overflow:hidden;
  padding:24px 22px 20px;
  display:flex;flex-direction:column;gap:14px;
}
.portal-card:hover{transform:translateY(-3px);border-color:rgba(255,255,255,.2);box-shadow:0 12px 40px rgba(0,0,0,.4);}
.portal-card::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .18s;}
.portal-card:hover::before{opacity:1;}

/* Ministry */
.pc-ministry{background:linear-gradient(135deg,#0d1b35 0%,#1a2d58 100%);}
.pc-ministry::before{background:linear-gradient(135deg,rgba(37,99,235,.15),transparent);}
.pc-ministry .pc-accent{background:linear-gradient(90deg,var(--blue),#60a5fa);}

/* Soldier */
.pc-soldier{background:linear-gradient(135deg,#0d1207 0%,#1a2810 100%);}
.pc-soldier::before{background:linear-gradient(135deg,rgba(201,150,42,.12),transparent);}
.pc-soldier .pc-accent{background:linear-gradient(90deg,var(--gold),var(--gold2));}

/* Company */
.pc-company{background:linear-gradient(135deg,#0a1520 0%,#0f2236 100%);}
.pc-company::before{background:linear-gradient(135deg,rgba(8,145,178,.12),transparent);}
.pc-company .pc-accent{background:linear-gradient(90deg,var(--teal),#22d3ee);}

/* Investor */
.pc-investor{background:linear-gradient(135deg,#1a0e05 0%,#2d1a08 100%);}
.pc-investor::before{background:linear-gradient(135deg,rgba(201,150,42,.1),transparent);}
.pc-investor .pc-accent{background:linear-gradient(90deg,var(--gold),#a16207);}

.pc-accent{position:absolute;top:0;left:0;right:0;height:3px;}
.pc-icon{font-size:26px;}
.pc-name{font-size:15px;font-weight:700;color:#fff;letter-spacing:-.2px;}
.pc-role{font-size:11px;color:var(--mid);margin-top:2px;}
.pc-desc{font-size:11px;color:var(--dim);line-height:1.5;}
.pc-enter{
  display:flex;align-items:center;justify-content:space-between;
  padding:7px 12px;border-radius:8px;
  border:1px solid rgba(255,255,255,.1);
  font-size:11px;font-weight:700;color:rgba(255,255,255,.55);
  margin-top:4px;transition:all .15s;
}
.portal-card:hover .pc-enter{color:#fff;border-color:rgba(255,255,255,.25);background:rgba(255,255,255,.06);}

/* ══ TOPBAR (app mode) ══ */
#app-topbar{
  display:none;align-items:center;gap:0;
  background:var(--ink2);border-bottom:1px solid rgba(255,255,255,.07);
  padding:0 20px;flex-shrink:0;z-index:100;position:relative;
}
#app-topbar.visible{display:flex;}

.app-brand{display:flex;align-items:center;gap:10px;padding:12px 16px 12px 0;border-left:1px solid rgba(255,255,255,.08);margin-left:20px;}
.app-logo{width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,var(--gold),var(--gold2));display:flex;align-items:center;justify-content:center;font-size:13px;}
.app-name{font-size:13px;font-weight:700;color:#fff;}
.app-name em{color:var(--gold2);font-style:normal;}

.portal-tabs{display:flex;gap:2px;}
.ptab{
  display:flex;align-items:center;gap:7px;
  padding:14px 16px;font-size:12px;font-weight:600;
  color:rgba(255,255,255,.4);cursor:pointer;
  border-bottom:2px solid transparent;transition:all .15s;
  white-space:nowrap;
}
.ptab:hover{color:rgba(255,255,255,.75);}
.ptab.active{color:#fff;border-bottom-color:currentColor;}
.ptab.t-ministry.active{color:#60a5fa;border-bottom-color:#60a5fa;}
.ptab.t-soldier.active{color:var(--gold2);border-bottom-color:var(--gold2);}
.ptab.t-company.active{color:#22d3ee;border-bottom-color:#22d3ee;}
.ptab.t-investor.active{color:var(--gold2);border-bottom-color:var(--gold2);}

.app-right{margin-right:auto;display:flex;align-items:center;gap:10px;}
.user-pill{
  display:flex;align-items:center;gap:7px;
  padding:5px 12px;border-radius:20px;
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);
  font-size:11px;color:var(--mid);
}
.user-av{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0;}
.logout-btn{
  padding:5px 14px;border-radius:7px;border:1px solid rgba(255,255,255,.12);
  background:transparent;color:rgba(255,255,255,.5);font-size:11px;font-weight:600;
  font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s;
}
.logout-btn:hover{border-color:rgba(239,68,68,.5);color:#fca5a5;background:rgba(239,68,68,.06);}

/* ══ IFRAME SHELL ══ */
#iframe-shell{flex:1;position:relative;display:none;}
#iframe-shell.visible{display:block;}
.portal-frame{
  position:absolute;inset:0;width:100%;height:100%;
  border:none;background:#fff;
  opacity:0;pointer-events:none;transition:opacity .2s ease;
}
.portal-frame.active{opacity:1;pointer-events:auto;}

/* ══ LOADING ══ */
.frame-loading{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--ink);z-index:10;
  transition:opacity .3s ease;
  gap:14px;
}
.frame-loading.done{opacity:0;pointer-events:none;}
.loading-spinner{
  width:36px;height:36px;border-radius:50%;
  border:3px solid rgba(255,255,255,.1);
  border-top-color:var(--gold2);
  animation:spin .8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}
.loading-text{font-size:12px;color:var(--mid);font-family:'DM Mono',monospace;}

/* ══ PORTAL SWITCH ANIMATION ══ */
@keyframes portalIn{from{opacity:0;transform:scale(.99);}to{opacity:1;transform:scale(1);}}
.portal-frame.active{animation:portalIn .22s ease;}
</style>
</head>
<body>

