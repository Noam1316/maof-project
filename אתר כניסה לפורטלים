  investor: { name:'משה לוי · Board Member',   av:'מל', avBg:'linear-gradient(135deg,#c9962a,#1a0e05)', tabColor:'#e8b84b' },
};

const SRCDOC = {
  ministry: `&lt;!DOCTYPE html&gt;
