.btn{
  padding:9px 20px;border-radius:10px;font-family:&#x27;Heebo&#x27;,sans-serif;
  font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s;border:none;
}
.btn-gold{background:var(--gold);color:#0d0f14;}
.btn-gold:hover{background:var(--gold-dim);transform:translateY(-1px);}
.btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border2);}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold);}

/* ── CARDS ─────────────────────────────── */
.panel{background:var(--card);border:1px solid var(--border2);border-radius:14px;padding:22px;}
.panel-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;}
.panel-title{font-size:14px;font-weight:700;color:#fff;}
.panel-action{font-size:11px;color:var(--gold);cursor:pointer;font-family:&#x27;IBM Plex Mono&#x27;,monospace;}

/* ── KPI CARDS ─────────────────────────────── */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px;}
.kpi-card{
  background:var(--card);border:1px solid var(--border2);border-radius:14px;padding:18px;
  position:relative;overflow:hidden;transition:transform 0.2s;
}
.kpi-card:hover{transform:translateY(-2px);}
.kpi-card::after{content:&#x27;&#x27;;position:absolute;bottom:0;left:0;right:0;height:2px;}
.kpi-card.gold::after{background:var(--gold);}
.kpi-card.teal::after{background:var(--teal);}
.kpi-card.amber::after{background:var(--amber);}
.kpi-card.blue::after{background:var(--blue);}
.kpi-label{font-size:10px;font-family:&#x27;IBM Plex Mono&#x27;,monospace;color:var(--text-dim);letter-spacing:0.5px;margin-bottom:8px;}
.kpi-val{font-size:30px;font-weight:900;line-height:1;}
.kpi-val.gold{color:var(--gold);}
.kpi-val.teal{color:var(--teal);}
.kpi-val.amber{color:var(--amber);}
.kpi-val.blue{color:var(--blue);}
.kpi-sub{font-size:11px;color:var(--text-dim);margin-top:5px;}

/* ── JOURNEY TIMELINE ─────────────────────────────── */
.journey-track{
  display:grid;grid-template-columns:1fr 40px 1fr 40px 1fr;
  gap:0;align-items:start;margin:8px 0 24px;
}
.journey-node{
  border-radius:14px;padding:18px;
  text-align:center;border:1.5px solid var(--border2);
  background:var(--card2);position:relative;
  transition:all 0.3s;
}
.journey-node:hover{transform:translateY(-3px);}
.journey-node.highlight{border-color:rgba(245,200,66,0.4);background:rgba(245,200,66,0.05);}
.journey-node.phase-b{border-color:rgba(0,212,170,0.3);background:rgba(0,212,170,0.04);}
.phase-badge{
  position:absolute;top:-11px;right:50%;transform:translateX(50%);
  font-size:9px;font-weight:900;padding:2px 10px;border-radius:4px;letter-spacing:1px;
  white-space:nowrap;
}
.phase-badge.gold{background:var(--gold);color:#0d0f14;}
.phase-badge.teal{background:var(--teal);color:#0d0f14;}
.phase-badge.blue{background:var(--blue);color:#0d0f14;}
.journey-icon{font-size:28px;margin-bottom:8px;}
.journey-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;}
.journey-title{font-size:15px;font-weight:900;color:#fff;margin-bottom:4px;}
.journey-detail{font-size:11px;color:var(--text-dim);line-height:1.5;}
.journey-match{font-size:14px;font-weight:900;font-family:&#x27;IBM Plex Mono&#x27;,monospace;margin-top:8px;}
.journey-arrow{display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--gold);padding-top:40px;}

/* ── OPTION CARDS ─────────────────────────────── */
.options-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.option-card{
  background:var(--card2);border:1.5px solid var(--border2);
  border-radius:12px;padding:16px;cursor:pointer;
  transition:all 0.2s;position:relative;overflow:hidden;
}
.option-card:hover{border-color:rgba(245,200,66,0.3);transform:translateY(-2px);}
.option-card.selected{border-color:var(--gold);background:rgba(245,200,66,0.06);}
.option-card.best::before{
  content:&#x27;המלצה 🏆&#x27;;position:absolute;top:0;left:0;
  background:var(--gold);color:#0d0f14;font-size:9px;font-weight:900;
  padding:3px 10px;border-radius:0 0 8px 0;letter-spacing:0.5px;
}
.opt-rank{font-size:11px;font-family:&#x27;IBM Plex Mono&#x27;,monospace;color:var(--text-dim);margin-bottom:6px;}
.opt-name{font-size:14px;font-weight:800;color:#fff;margin-bottom:4px;}
.opt-detail{font-size:11px;color:var(--text-dim);line-height:1.5;margin-bottom:10px;}
.opt-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px;}
.opt-tag{font-size:10px;padding:2px 7px;border-radius:4px;font-weight:600;}
.opt-score-row{display:flex;align-items:center;justify-content:space-between;}
.opt-score{font-size:18px;font-weight:900;font-family:&#x27;IBM Plex Mono&#x27;,monospace;}
.match-bar{height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;margin-top:6px;}
.match-fill{height:100%;border-radius:2px;transition:width 1s ease;}

/* ── SCORE RING ─────────────────────────────── */
.score-ring-wrap{position:relative;display:inline-block;}
.score-ring-text{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  font-family:&#x27;IBM Plex Mono&#x27;,monospace;font-weight:900;
}

/* ── UPSKILL PATH ─────────────────────────────── */
.upskill-track{display:flex;flex-direction:column;gap:8px;}
.upskill-step{
  display:flex;align-items:center;gap:14px;
  padding:12px 16px;background:var(--card2);border-radius:10px;
  border:1px solid var(--border2);transition:all 0.2s;
}
.upskill-step:hover{border-color:rgba(245,200,66,0.2);}
.upskill-step.done{border-color:rgba(0,212,170,0.25);background:rgba(0,212,170,0.04);}
.upskill-step.locked{opacity:0.5;}
.step-num{
  width:28px;height:28px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:900;flex-shrink:0;
}
.step-done{background:var(--teal);color:#0d0f14;}
.step-active{background:var(--gold);color:#0d0f14;}
.step-locked{background:rgba(255,255,255,0.08);color:var(--text-dim);}
.step-info{flex:1;}
.step-title{font-size:13px;font-weight:700;color:#fff;}
.step-meta{font-size:11px;color:var(--text-dim);margin-top:1px;}
.step-impact{font-size:11px;font-weight:700;font-family:&#x27;IBM Plex Mono&#x27;,monospace;}

/* ── SIMULATOR ─────────────────────────────── */
.sim-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.sim-control{display:flex;flex-direction:column;gap:14px;}
.sim-label{font-size:12px;color:var(--text-dim);margin-bottom:4px;font-family:&#x27;IBM Plex Mono&#x27;,monospace;}
.sim-slider{width:100%;accent-color:var(--gold);height:4px;cursor:pointer;}
.sim-val{font-family:&#x27;IBM Plex Mono&#x27;,monospace;font-size:13px;font-weight:700;color:var(--gold);}
.sim-output{display:flex;flex-direction:column;gap:10px;}
.sim-row{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--card2);border-radius:8px;}
.sim-row-label{font-size:12px;color:var(--text-dim);}
.sim-row-val{font-size:14px;font-weight:900;font-family:&#x27;IBM Plex Mono&#x27;,monospace;}

/* ── SALARY BREAKDOWN ─────────────────────────────── */
.salary-timeline{display:flex;flex-direction:column;gap:10px;}
.sal-row{display:flex;align-items:center;gap:12px;}
.sal-phase{font-size:11px;color:var(--text-dim);width:80px;flex-shrink:0;text-align:left;}
.sal-bar-wrap{flex:1;}
.sal-bar{height:28px;border-radius:6px;display:flex;align-items:center;padding:0 12px;font-size:12px;font-weight:700;color:#0d0f14;transition:width 0.8s ease;}
.sal-amount{font-size:13px;font-weight:900;font-family:&#x27;IBM Plex Mono&#x27;,monospace;width:80px;text-align:left;}

/* ── CHECKLIST ─────────────────────────────── */
.check-list{display:flex;flex-direction:column;gap:8px;}
.check-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 14px;background:var(--card2);border-radius:10px;
  border:1px solid var(--border2);
}
.check-icon{font-size:18px;flex-shrink:0;}
.check-text{flex:1;}
.check-title{font-size:13px;font-weight:600;color:#fff;}
.check-sub{font-size:11px;color:var(--text-dim);}
.check-status{font-size:11px;font-weight:700;padding:3px 8px;border-radius:5px;}
.status-done{background:rgba(0,212,170,0.15);color:var(--teal);}
.status-pending{background:rgba(245,200,66,0.12);color:var(--gold);}
.status-todo{background:rgba(255,255,255,0.06);color:var(--text-dim);}

/* ── ALERT ─────────────────────────────── */
.alert{
  background:rgba(245,200,66,0.08);border:1px solid rgba(245,200,66,0.25);
  border-radius:12px;padding:14px 18px;display:flex;align-items:center;gap:12px;
  margin-bottom:22px;font-size:13px;
}
.alert-icon{font-size:18px;flex-shrink:0;}
.alert strong{color:var(--gold);}
.alert-cta{margin-right:auto;font-size:12px;color:var(--gold);cursor:pointer;text-decoration:underline;white-space:nowrap;}

/* ── PROGRESS BAR ─────────────────────────────── */
.prog-wrap{background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden;}
.prog-fill{height:100%;border-radius:4px;transition:width 1s ease;}

/* ── TABS ─────────────────────────────── */
.tab-bar{display:flex;gap:4px;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:4px;margin-bottom:22px;}
.tab-btn{
  flex:1;padding:9px 16px;border-radius:8px;text-align:center;
  cursor:pointer;font-size:13px;font-weight:600;color:var(--text-dim);transition:all 0.2s;
}
.tab-btn.active{background:rgba(245,200,66,0.15);color:var(--gold);}
.tab-content{display:none;}
.tab-content.active{display:block;animation:fadeUp 0.2s ease;}

/* ── NOTIFICATION BADGE ─────────────────────────────── */
.notif-badge{background:var(--red);color:#fff;font-size:9px;font-weight:900;padding:1px 5px;border-radius:8px;margin-right:auto;}


/* ── SETTINGS SCREEN ─────────────────────────────── */
.settings-form{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.settings-field{display:flex;flex-direction:column;gap:8px;}
.settings-field.full{grid-column:span 2;}
.settings-label{font-size:11px;color:var(--text-dim);font-family:&#x27;IBM Plex Mono&#x27;,monospace;letter-spacing:0.5px;text-transform:uppercase;}
.settings-input{
  background:var(--card2);border:1px solid var(--border2);border-radius:10px;
  padding:12px 16px;font-family:&#x27;Heebo&#x27;,sans-serif;font-size:15px;
  color:var(--text);outline:none;transition:border-color 0.2s;width:100%;
}
.settings-input:focus{border-color:var(--gold);}
select.settings-input{cursor:pointer;-webkit-appearance:none;}
.tech-chips{display:flex;flex-wrap:wrap;gap:8px;}
.tech-chip{
  padding:7px 14px;border-radius:8px;font-size:13px;font-weight:600;
  border:1.5px solid var(--border2);background:var(--card2);
  cursor:pointer;transition:all 0.15s;color:var(--text-dim);
}
.tech-chip:hover{border-color:var(--gold);color:var(--gold);}
.tech-chip.selected{border-color:var(--gold);background:rgba(245,200,66,0.12);color:var(--gold);}
.settings-save-bar{
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(245,200,66,0.06);border:1px solid rgba(245,200,66,0.2);
  border-radius:12px;padding:14px 20px;margin-top:24px;
}

