let loaded = {};
let currentPortal = null;

function login(portal) {
  const ls = document.getElementById('login-screen');
  ls.classList.add('login-screen-hidden');

  const u = USERS[portal];
  document.getElementById('user-av').textContent    = u.av;
  document.getElementById('user-av').style.background = u.avBg;
  document.getElementById('user-name').textContent  = u.name;

  setTimeout(() => {
    ls.style.display = 'none';
    document.getElementById('app-topbar').classList.add('visible');
    document.getElementById('iframe-shell').classList.add('visible');
    switchPortal(portal);
  }, 280);
}

function switchPortal(portal) {
  // Update tab highlights
  document.querySelectorAll('.ptab').forEach(t => t.classList.remove('active'));
  document.querySelector('.t-' + portal).classList.add('active');

  // Hide all frames
  document.querySelectorAll('.portal-frame').forEach(f => f.classList.remove('active'));

  const frame = document.getElementById('f-' + portal);
  const loading = document.getElementById('frame-loading');

  if (!loaded[portal]) {
    loading.classList.remove('done');
    frame.srcdoc = SRCDOC[portal];
    frame.onload = () => {
      loaded[portal] = true;
      loading.classList.add('done');
      frame.classList.add('active');
    };
    loaded[portal] = 'loading';
  } else if (loaded[portal] === true) {
    loading.classList.add('done');
    frame.classList.add('active');
  }

  currentPortal = portal;
}

function logout() {
  // Reset
  loaded = {};
  currentPortal = null;
  document.querySelectorAll('.portal-frame').forEach(f => {
    f.classList.remove('active');
    f.srcdoc = '';
  });
  document.querySelectorAll('.ptab').forEach(t => t.classList.remove('active'));
  document.getElementById('frame-loading').classList.remove('done');
  document.getElementById('app-topbar').classList.remove('visible');
  document.getElementById('iframe-shell').classList.remove('visible');

  const ls = document.getElementById('login-screen');
  ls.style.display = 'flex';
  ls.classList.remove('login-screen-hidden');
}
</script>
</body>
